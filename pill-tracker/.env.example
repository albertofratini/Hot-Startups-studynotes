# ---- Copy this file to ".env" and fill in your values ----

# Server
PORT=3000

# Optional secret code so only you two can open the app (leave blank for no gate)
APP_PASSCODE=

# Where the data file lives (defaults to ./data)
# DATA_DIR=./data

# ---- Defaults (can also be changed later in the app's Settings screen) ----
HER_NAME=Basia
PILL_TIME=21:30
TIMEZONE=Europe/Paris
HER_WHATSAPP=+33XXXXXXXXX
PARTNER_WHATSAPP=+33XXXXXXXXX

# Times (24h, comma-separated) when reminders go to BOTH of you until she ticks
# it. A time earlier than PILL_TIME fires the next morning (e.g. 09:00).
REMINDER_TIMES=22:00,23:00,09:00

# Optional extra alert sent ONLY to you if she hasn't ticked it by this time.
# Off by default (the reminders above already include you). Set to 1 to enable.
PARTNER_ALERT_ENABLED=0
PARTNER_ALERT_TIME=23:30

# Cycle / period tracking (optional — also configurable in Settings).
# Set the first active-pill date of her current pack and the pack pattern.
CYCLE_START=
CYCLE_ACTIVE=21
CYCLE_BREAK=7

# ---- Twilio WhatsApp ----
# Get these from https://console.twilio.com  (Messaging > Try it out > WhatsApp)
# If you leave the SID/TOKEN blank, the app runs in DEV mode and just prints
# the messages to the server console instead of sending them.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio sandbox number is whatsapp:+14155238886 (default). Replace once you have
# your own approved WhatsApp sender.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
